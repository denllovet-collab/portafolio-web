/* SELECTORES DE ETIQUETA */
body {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    background-color: #f4edff; /* lila muy claro */
}

h1, h2 {
    color: #2b2b2b;
}

p {
    color: #555555;
    font-size: 14px;
}
/*SUBTITULOS*/
.card h2 {
    font-family: 'Playfair Display', serif;
    font-weight: 600;
}
#main-header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 38px;
    font-weight: 600;
}

/* SELECTORES DE ID */
#main-header {
    background-color: #111;
    color: white;
    text-align: center;
    padding: 30px;
}
#main-header h1,
#main-header p {
    color: white;
}

#main-footer {
    text-align: center;
    padding: 15px;
    background-color: #111;
    color: white;
}

/* CONTENEDOR FLEX */
.container {
    display: flex;
    gap: 20px;
    padding: 30px;
    justify-content: center;
    flex-wrap: wrap;
}

/* SELECTORES DE CLASE */
.card {
    background-color: white;
    width: 300px;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 5px 10px rgba(0,0,0,0.1);
    box-sizing: border-box;

    /* Hover y animación */
    border: 2px solid transparent;
    transition: border 0.3s ease, transform 0.3s ease;
}

/* EFECTO HOVER */
.card:hover {
    border: 2px solid #c77dff;
    transform: translateY(-5px);
}

.card img {
    width: 100%;
    border-radius: 8px;
}

.card ul {
    padding-left: 20px;
}

.card li {
    font-size: 13px;
    color: #444;
}

/* BOTONES */
.buttons {
    display: flex;
    justify-content: space-between;
    margin-top: 15px;
}

.btn {
    text-decoration: none;
    background-color: #c77dff;
    color: white;
    padding: 8px 12px;
    border-radius: 5px;
    font-size: 13px;
}

.btn-secondary {
    background-color: #555;
}

/* RESPONSIVE */
@media (max-width: 768px) {
    .container {
        flex-direction: column;
        align-items: center;
    }
}
