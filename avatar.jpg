<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Formulario de Contacto</title>
    <link rel="stylesheet" href="styles.css">
</head>

<body>

<div class="container">

    <h1>Formulario de Contacto</h1>
    <p>Completa el siguiente formulario para ponerte en contacto conmigo.</p>

    <form id="form-contacto">

        <!-- Nombre -->
        <label for="nombre">Nombre completo</label>
        <input 
            type="text" 
            id="nombre" 
            placeholder="Ingresa tu nombre completo"
            required
        >

        <!-- Correo -->
        <label for="correo">Correo electrónico</label>
        <input 
            type="email" 
            id="correo"
            placeholder="ejemplo@correo.com"
            required
        >

        <!-- Teléfono -->
        <label for="telefono">Teléfono</label>
        <input 
            type="tel" 
            id="telefono"
            placeholder="55 1234 5678"
            required
        >

        <!-- Asunto -->
        <label for="asunto">Asunto</label>
        <select id="asunto" required>
            <option value="">Selecciona un asunto</option>
            <option>Oferta laboral</option>
            <option>Colaboración</option>
            <option>Consulta técnica</option>
            <option>Otro</option>
        </select>

        <!-- Otro -->
        <label for="otro">Si seleccionaste "Otro", especifica</label>
        <input 
            type="text" 
            id="otro"
            placeholder="Especifica el motivo"
        >

        <!-- Mensaje -->
        <label for="mensaje">Mensaje</label>
        <textarea 
            id="mensaje" 
            placeholder="Describe tu mensaje en detalle..."
            required
        ></textarea>

        <!-- Términos -->
        <div class="terminos">
            <input type="checkbox" id="acepto" required>
            <label for="acepto">
                Acepto la política de privacidad y términos de uso
            </label>
        </div>

        <!-- Botones -->
        <div class="botones">
            <button type="submit">Enviar Mensaje</button>
            <button type="reset">Limpiar formulario</button>
        </div>

    </form>

</div>

</body>
</html>

